---
// Detail page — Neo-Brutalist
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Converter from '../../../components/Converter.astro';
import ConversionTable from '../../../components/ConversionTable.astro';
import CrossLinks from '../../../components/CrossLinks.astro';
import AdSense from '../../../components/AdSense.astro';
import UnitDescription from '../../../components/UnitDescription.astro';
import NumberBase from '../../../components/calculators/NumberBase.astro';
import { t, type Lang, LANGUAGES, LANG_LABELS } from 'converter-core/utils/i18n';
import { getCategory, getUnit, convert, formatResult, getUnitPairs, pairSlug, valueSlug, getCommonValues } from 'converter-core/lib/units';
import { categories } from 'converter-core/data/units';
import { unitDescriptions } from 'converter-core/data/descriptions';
import { NUMBER_BASE_VALUES, numberBaseSlug, parseNumberBaseSlug, baseDisplayName, parseBaseValue } from 'converter-core/data/number-base-values';

export interface Props { lang: Lang; category: string; slug: string[]; }

export function getStaticPaths() {
  const paths: Array<{ params: Props }> = [];
  for (const lang of LANGUAGES) {
    for (const cat of categories) {
      // Calculator categories: only number-base has value pages
      if (cat.type === 'calculator') {
        if (cat.id === 'number-base') {
          for (const conv of NUMBER_BASE_VALUES) {
            paths.push({ params: { lang, category: cat.id, slug: [numberBaseSlug(conv, lang)] } });
          }
        }
        continue;
      }
      const pairs = getUnitPairs(cat);
      const commonValues = getCommonValues(cat.id);
      for (const [u1, u2] of pairs) {
        paths.push({ params: { lang, category: cat.id, slug: pairSlug(u1, u2, lang) } });
        for (const val of commonValues) {
          paths.push({ params: { lang, category: cat.id, slug: valueSlug(val, u1, u2, lang) } });
        }
      }
    }
  }
  return paths;
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string | string[] };
const catId = Astro.params.category as string;
const category = getCategory(catId);
if (!category || !slug) return Astro.redirect(`/${lang}/`);
const rawSlug = Array.isArray(slug) ? slug.join('/') : slug;
if (!rawSlug) return Astro.redirect(`/${lang}/${catId}/`);
// Calculator categories: redirect any detail page to their index page,
// except number-base which has SEO value pages
if (category.type === 'calculator' && catId !== 'number-base') return Astro.redirect(`/${lang}/${catId}/`);

// Check if this is a number-base value page
let isNumberBasePage = false;
let nbDecimalValue = 0;
let nbFromName = '';
let nbToName = '';
let nbResult = '';
let nbFromBase = '';
let nbToBase = '';

if (catId === 'number-base') {
  const nbParsed = parseNumberBaseSlug(rawSlug, lang);
  if (nbParsed) {
    isNumberBasePage = true;
    nbDecimalValue = nbParsed.decimalValue;
    nbFromName = baseDisplayName(nbParsed.conv.from, lang);
    nbToName = baseDisplayName(nbParsed.conv.to, lang);
    nbResult = nbParsed.result;
    nbFromBase = nbParsed.conv.from;
    nbToBase = nbParsed.conv.to;
  } else {
    // Invalid number-base slug → redirect to index
    return Astro.redirect(`/${lang}/${catId}/`);
  }
}

interface PageData { unit1Id: string; unit2Id: string; value: number | null; }
function parseSlug(slugStr: string, cat: typeof category, l: Lang): PageData | null {
  if (!cat) return null;
  if (l === 'zh') {
    const match = slugStr.match(/^(\d+)-(.*)$/);
    if (match) { const val = parseInt(match[1], 10); const rest = match[2]; const parts = rest.split('-'); if (parts.length !== 2) return null; const u1 = cat.units.find(u => u.name.zh === parts[0]); const u2 = cat.units.find(u => u.name.zh === parts[1]); if (u1 && u2) return { unit1Id: u1.id, unit2Id: u2.id, value: val }; }
    else { const parts = slugStr.split('-'); if (parts.length !== 2) return null; const u1 = cat.units.find(u => u.name.zh === parts[0]); const u2 = cat.units.find(u => u.name.zh === parts[1]); if (u1 && u2) return { unit1Id: u1.id, unit2Id: u2.id, value: null }; }
  } else {
    const match = slugStr.match(/^(\d+)-(.*)$/);
    if (match) { const val = parseInt(match[1], 10); const rest = match[2]; const parts = rest.split('-to-'); if (parts.length !== 2) return null; const u1 = cat.units.find(u => u.id === parts[0]); const u2 = cat.units.find(u => u.id === parts[1]); if (u1 && u2) return { unit1Id: u1.id, unit2Id: u2.id, value: val }; }
    else { const parts = slugStr.split('-to-'); if (parts.length !== 2) return null; const u1 = cat.units.find(u => u.id === parts[0]); const u2 = cat.units.find(u => u.id === parts[1]); if (u1 && u2) return { unit1Id: u1.id, unit2Id: u2.id, value: null }; }
  }
  return null;
}

// For number-base pages, skip standard converter parsing
let parsed: PageData | null = null;
let unit1Id = '';
let unit2Id = '';
let value: number | null = null;
let u1: any = null;
let u2: any = null;

if (!isNumberBasePage) {
  parsed = parseSlug(rawSlug, category, lang);
  if (!parsed) return Astro.redirect(`/${lang}/${catId}/`);
  unit1Id = parsed.unit1Id;
  unit2Id = parsed.unit2Id;
  value = parsed.value;
  u1 = getUnit(category, unit1Id);
  u2 = getUnit(category, unit2Id);
  if (!u1 || !u2) return Astro.redirect(`/${lang}/${catId}/`);
}

const catName = category.name[lang];

// ---------- Number Base value page data ----------
let nbPageTitle = '';
let nbPageDesc = '';
let nbHeading = '';
let nbJsonld = '';
let nbPagePath = '';

if (isNumberBasePage) {
  const nbValueStr = String(nbDecimalValue);
  const nbSlug = rawSlug;
  nbPagePath = `${catId}/${nbSlug}`;

  if (lang === 'zh') {
    nbPageTitle = `${nbValueStr}的${nbFromName}转${nbToName} - ${nbFromName}转${nbToName}转换器`;
    nbPageDesc = `将${nbValueStr} (${nbFromName}) 转换为${nbToName}。${nbValueStr}的${nbFromName}等于${nbResult}的${nbToName}。免费在线${nbFromName}转${nbToName}转换器。`;
    nbHeading = `${nbValueStr} (${nbFromName}) = ${nbResult} (${nbToName})`;
  } else {
    nbPageTitle = `${nbValueStr} in ${nbFromName} to ${nbToName} - ${nbFromName} to ${nbToName} Converter`;
    nbPageDesc = `Convert ${nbValueStr} (${nbFromName}) to ${nbToName}. ${nbValueStr} in ${nbFromName} equals ${nbResult} in ${nbToName}. Free online ${nbFromName} to ${nbToName} converter.`;
    nbHeading = `${nbValueStr} (${nbFromName}) = ${nbResult} (${nbToName})`;
  }

  const nbBreadcrumb = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: t(lang, 'nav.home'), item: `${Astro.site}${lang}/` },
    { '@type': 'ListItem', position: 2, name: catName, item: `${Astro.site}${lang}/${catId}/` },
    { '@type': 'ListItem', position: 3, name: `${nbFromName} → ${nbToName}` },
  ]};
  let q1: string, q1a: string, q2: string, q2a: string;
  if (lang === 'zh') {
    q1 = `${nbValueStr}的${nbFromName}等于多少${nbToName}？`;
    q1a = `${nbValueStr}的${nbFromName}等于${nbResult}的${nbToName}。`;
    q2 = `${nbFromName}和${nbToName}之间如何换算？`;
    q2a = `${nbFromName}是基数为${parseBaseValue('1', nbFromBase)}的进制，${nbToName}是基数为${parseBaseValue('1', nbToBase)}的进制。要将${nbFromName}转换为${nbToName}，先将${nbFromName}值转换为十进制，再将十进制结果转换为${nbToName}。`;
  } else {
    q1 = `What is ${nbValueStr} in ${nbFromName} to ${nbToName}?`;
    q1a = `${nbValueStr} in ${nbFromName} equals ${nbResult} in ${nbToName}.`;
    q2 = `How do you convert ${nbFromName} to ${nbToName}?`;
    q2a = `${nbFromName} is base-${parseBaseValue('1', nbFromBase)} and ${nbToName} is base-${parseBaseValue('1', nbToBase)}. To convert from ${nbFromName} to ${nbToName}, first convert the ${nbFromName} value to decimal, then convert the decimal result to ${nbToName}.`;
  }
  const nbFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [
    { '@type': 'Question', name: q1, acceptedAnswer: { '@type': 'Answer', text: q1a } },
    { '@type': 'Question', name: q2, acceptedAnswer: { '@type': 'Answer', text: q2a } },
  ]};
  nbJsonld = JSON.stringify([nbBreadcrumb, nbFaq]);
}

// ---------- Standard converter value page data ----------
let isConverterPage = false;
let displayValue = 0;
let result = 0;
let formattedResult = '';
let rate = 0;
let reverseRate = 0;
let u1Name = '';
let u2Name = '';
let pageSlug = '';
let pageTitle = '';
let pageDesc = '';
let heading = '';
let pagePath = '';
let jsonld = '';
let allUnits: Array<{ id: string; name: string; symbol: string }> = [];
let ratesMap: Record<string, number> = {};
let commonValuesForTable: number[] = [];

if (!isNumberBasePage) {
  isConverterPage = value === null;
  displayValue = value ?? 1;
  result = convert(category, displayValue, unit1Id, unit2Id);
  formattedResult = formatResult(result);
  rate = convert(category, 1, unit1Id, unit2Id);
  reverseRate = convert(category, 1, unit2Id, unit1Id);
  u1Name = u1.name[lang]; u2Name = u2.name[lang];
  pageSlug = isConverterPage ? pairSlug(u1, u2, lang) : rawSlug;
  pagePath = `${catId}/${pageSlug}`;

  pageTitle = isConverterPage ? t(lang, 'converter.pageTitleConverter', { unit1: u1Name, unit2: u2Name, name: catName }) : t(lang, 'converter.pageTitle', { value: String(displayValue), unit1: u1Name, unit2: u2Name, result: formattedResult });
  pageDesc = isConverterPage ? t(lang, 'converter.pageDescriptionConverter', { unit1: u1Name, unit2: u2Name, name: catName }) : t(lang, 'converter.pageDescription', { value: String(displayValue), unit1: u1Name, unit2: u2Name, result: formattedResult, name: catName });
  heading = isConverterPage ? t(lang, 'converter.headingConverter', { unit1: u1Name, unit2: u2Name }) : t(lang, 'converter.heading', { value: String(displayValue), unit1: u1Name, unit2: u2Name, result: formattedResult });

  const breadcrumbJsonld = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: t(lang, 'nav.home'), item: `${Astro.site}${lang}/` }, { '@type': 'ListItem', position: 2, name: catName, item: `${Astro.site}${lang}/${catId}/` }, { '@type': 'ListItem', position: 3, name: `${u1Name} → ${u2Name}` }] };
  const faqQuestions: Array<Record<string, any>> = [
    { '@type': 'Question', name: `${t(lang, 'converter.whatIsUnit', { unit: `${displayValue} ${u1Name}` })} ${lang === 'zh' || lang === 'ja' || lang === 'ko' ? '' : ''}${u2Name}${lang === 'zh' ? '换算结果是' : ' = '}${formattedResult} ${u2Name}`, acceptedAnswer: { '@type': 'Answer', text: `${displayValue} ${u1Name} = ${formattedResult} ${u2Name}. ${t(lang, 'converter.formula')}: 1 ${u1Name} = ${formatResult(rate)} ${u2Name}.` } },
    { '@type': 'Question', name: `1 ${u1Name} = ? ${u2Name}`, acceptedAnswer: { '@type': 'Answer', text: `1 ${u1Name} = ${formatResult(rate)} ${u2Name}.` } },
  ];
  const desc1 = unitDescriptions[catId]?.[unit1Id]; const desc2 = unitDescriptions[catId]?.[unit2Id];
  if (desc1) faqQuestions.push({ '@type': 'Question', name: t(lang, 'converter.whatIsUnit', { unit: u1Name }), acceptedAnswer: { '@type': 'Answer', text: desc1[lang] } });
  if (desc2) faqQuestions.push({ '@type': 'Question', name: t(lang, 'converter.whatIsUnit', { unit: u2Name }), acceptedAnswer: { '@type': 'Answer', text: desc2[lang] } });

  const faqJsonld = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqQuestions };
  const howToNameHeading = t(lang, 'converter.headingConverter', { unit1: u1Name, unit2: u2Name, name: catName });
  let howToSteps: Array<Record<string, any>>;
  if (category.convertFn) {
    if (unit1Id === 'f' && unit2Id === 'c') { howToSteps = [{ '@type': 'HowToStep', position: 1, text: lang === 'zh' ? '从华氏度值中减去32' : 'Subtract 32 from the Fahrenheit value' }, { '@type': 'HowToStep', position: 2, text: lang === 'zh' ? '将结果乘以5/9' : 'Multiply the result by 5/9' }, { '@type': 'HowToStep', position: 3, text: lang === 'zh' ? '得到的结果就是摄氏度' : 'The result is the temperature in Celsius' }]; }
    else if (unit1Id === 'c' && unit2Id === 'f') { howToSteps = [{ '@type': 'HowToStep', position: 1, text: lang === 'zh' ? '将摄氏度值乘以9/5' : 'Multiply the Celsius value by 9/5' }, { '@type': 'HowToStep', position: 2, text: lang === 'zh' ? '再加上32' : 'Add 32 to the result' }, { '@type': 'HowToStep', position: 3, text: lang === 'zh' ? '得到的结果就是华氏度' : 'The result is the temperature in Fahrenheit' }]; }
    else { howToSteps = [{ '@type': 'HowToStep', position: 1, text: lang === 'zh' ? `先将${u1Name}转换为摄氏度` : `First convert ${u1Name} to Celsius` }, { '@type': 'HowToStep', position: 2, text: lang === 'zh' ? `再将摄氏度转换为${u2Name}` : `Then convert Celsius to ${u2Name}` }]; }
  } else { howToSteps = [{ '@type': 'HowToStep', position: 1, text: lang === 'zh' ? `取${u1Name}的数值` : `Take the value in ${u1Name}` }, { '@type': 'HowToStep', position: 2, text: lang === 'zh' ? `乘以换算系数 ${formatResult(rate)}` : `Multiply by the conversion factor ${formatResult(rate)}` }, { '@type': 'HowToStep', position: 3, text: lang === 'zh' ? `得到的结果就是${u2Name}` : `The result is your value in ${u2Name}` }]; }
  const howToJsonld = { '@context': 'https://schema.org', '@type': 'HowTo', name: howToNameHeading, step: howToSteps };
  jsonld = JSON.stringify([breadcrumbJsonld, faqJsonld, howToJsonld]);
  allUnits = category.units.map(u => ({ id: u.id, name: u.name[lang], symbol: u.symbol }));
  ratesMap = {}; for (const u of category.units) ratesMap[u.id] = u.toBase;
  commonValuesForTable = getCommonValues(catId);
}

const finalTitle = isNumberBasePage ? nbPageTitle : pageTitle;
const finalDesc = isNumberBasePage ? nbPageDesc : pageDesc;
const finalPath = isNumberBasePage ? nbPagePath : pagePath;
const finalJsonld = isNumberBasePage ? nbJsonld : jsonld;
---

<BaseLayout lang={lang} title={finalTitle} description={finalDesc} pagePath={finalPath} jsonld={finalJsonld}>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href={"/" + lang + "/"}>{t(lang, 'nav.home')}</a>
    <span class="sep">/</span>
    <a href={"/" + lang + "/" + catId + "/"}>{catName}</a>
    <span class="sep">/</span>
    <span>{isNumberBasePage ? `${nbFromName} → ${nbToName}` : `${u1Name} → ${u2Name}`}</span>
  </nav>

  {isNumberBasePage && (
    <>
      <div class="direct-answer">
        <span class="answer-value">{nbDecimalValue}</span>
        <span class="answer-unit">{nbFromName}</span>
        <span class="answer-equals">=</span>
        <span class="answer-result">{nbResult}</span>
        <span class="answer-unit">{nbToName}</span>
      </div>
      <h1 class="nb-heading">{nbHeading}</h1>
      <NumberBase lang={lang} />
      <AdSense position="middle" />
      <section class="nb-faq">
        <h2>{lang === 'zh' ? '常见问题' : 'Frequently Asked Questions'}</h2>
        <details class="faq-item">
          <summary class="faq-q">{lang === 'zh' ? `${nbValueStr}的${nbFromName}等于多少${nbToName}？` : `What is ${nbValueStr} in ${nbFromName} to ${nbToName}?`}</summary>
          <p class="faq-a">{lang === 'zh' ? `${nbValueStr}的${nbFromName}等于${nbResult}的${nbToName}。直接使用上面的转换器输入数值即可获得结果。` : `${nbValueStr} in ${nbFromName} equals ${nbResult} in ${nbToName}. Use the converter above to try different values.`}</p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">{lang === 'zh' ? `${nbFromName}和${nbToName}之间如何换算？` : `How do you convert ${nbFromName} to ${nbToName}?`}</summary>
          <p class="faq-a">{lang === 'zh' ? `${nbFromName}（基数为${parseBaseValue('1', nbFromBase)}）转换为${nbToName}（基数为${parseBaseValue('1', nbToBase)}）：先将${nbFromName}值转换为十进制，再将十进制结果转换为${nbToName}。` : `To convert from ${nbFromName} (base-${parseBaseValue('1', nbFromBase)}) to ${nbToName} (base-${parseBaseValue('1', nbToBase)}): first convert the ${nbFromName} value to decimal, then convert the decimal result to ${nbToName}.`}</p>
        </details>
      </section>
    </>
  )}

  {!isNumberBasePage && (
    <>
      {!isConverterPage && (
        <div class="direct-answer">
          <span class="answer-value">{displayValue} {u1.symbol}</span>
          <span class="answer-equals">=</span>
          <span class="answer-result">{formattedResult} {u2.symbol}</span>
        </div>
      )}

      <Converter lang={lang} categoryName={catName} unit1Id={unit1Id} unit1Name={u1Name} unit1Symbol={u1.symbol} unit2Id={unit2Id} unit2Name={u2Name} unit2Symbol={u2.symbol} initialValue={isConverterPage ? 1 : displayValue} rate={rate} reverseRate={reverseRate} initialResult={formattedResult} allUnits={allUnits} ratesMap={ratesMap} hasCustomConvert={!!category.convertFn} />

      {isConverterPage && <h1 class="converter-heading">{heading}</h1>}

      <section class="formula-section">
        <h2>{t(lang, 'converter.formula')}</h2>
        <div class="formula-cards">
          <div class="formula-card"><code>{t(lang, 'converter.formulaText', { unit1: u1Name, unit2: u2Name, rate: formatResult(rate) })}</code></div>
          <div class="formula-card"><code>{t(lang, 'converter.reverseFormulaText', { unit2: u2Name, unit1: u1Name, reverseRate: formatResult(reverseRate) })}</code></div>
        </div>
      </section>

      <AdSense position="middle" />

      <ConversionTable lang={lang} unit1Name={u1Name} unit2Name={u2Name} rate={rate} values={commonValuesForTable} />

      <UnitDescription lang={lang} unit={u1} categoryId={catId} />
      <UnitDescription lang={lang} unit={u2} categoryId={catId} />

      <AdSense position="bottom" />

      <CrossLinks lang={lang} categoryId={catId} unit1Id={unit1Id} unit2Id={unit2Id} unit1Name={u1Name} unit2Name={u2Name} />
    </>
  )}

  <p class="lang-hint">
    {LANGUAGES.filter(l => l !== lang).slice(0, 5).map((l, i) => (
      <>
        {i > 0 && ' · '}
        <a href={"/" + l + "/" + finalPath + "/"}>{LANG_LABELS[l] ?? l.toUpperCase()}</a>
      </>
    ))}
  </p>
</BaseLayout>

<style>
  .breadcrumbs { font-size: var(--text-sm); margin-bottom: var(--sp-4); color: var(--c-text-tertiary); display: flex; align-items: center; gap: var(--sp-1); flex-wrap: wrap; }
  .breadcrumbs a { color: var(--c-text-secondary); text-decoration: none; }
  .breadcrumbs a:hover { text-decoration: underline; }
  .sep { opacity: 0.4; }
  .converter-heading { font-size: var(--text-xl); margin: var(--sp-4) 0; letter-spacing: -0.01em; }
  .direct-answer {
    background: var(--c-accent);
    border: var(--b);
    box-shadow: var(--shadow-hard-sm);
    padding: var(--sp-4) var(--sp-5);
    margin: var(--sp-4) 0;
    display: flex;
    align-items: baseline;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .answer-value { font-size: var(--text-xl); font-weight: 700; }
  .answer-equals { font-size: var(--text-lg); color: var(--c-text-secondary); }
  .answer-result { font-size: var(--text-xl); font-weight: 700; }
  .formula-section { margin: var(--sp-8) 0; }
  .formula-section h2 {
    font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--c-text-tertiary); margin-bottom: var(--sp-3);
  }
  .formula-cards { display: flex; gap: var(--sp-3); flex-wrap: wrap; }
  .formula-card {
    background: var(--c-surface); border: 2px solid var(--c-border);
    padding: var(--sp-3) var(--sp-4); flex: 1; min-width: 200px;
  }
  .formula-card code { font-family: var(--font-mono); font-size: var(--text-sm); }
  .lang-hint {
    font-size: var(--text-sm); color: var(--c-text-tertiary);
    margin-top: var(--sp-10); text-align: center;
    padding: var(--sp-3) 0; border-top: 2px solid var(--c-border);
  }
  .lang-hint a { color: var(--c-text-secondary); text-decoration: underline; text-underline-offset: 2px; }
  .lang-hint a:hover { color: var(--c-text); }
  .answer-unit { font-size: var(--text-base); font-weight: 500; color: var(--c-text-secondary); }
  .nb-heading { font-size: var(--text-2xl); margin: var(--sp-4) 0; letter-spacing: -0.01em; }
  .nb-faq { margin: var(--sp-8) 0; }
  .nb-faq h2 {
    font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--c-text-tertiary); margin-bottom: var(--sp-4);
  }
  .faq-item { border: var(--b); margin-bottom: var(--sp-2); background: var(--c-surface); }
  .faq-q { padding: var(--sp-3) var(--sp-4); cursor: pointer; font-weight: 600; font-size: var(--text-sm); }
  .faq-q:hover { background: var(--c-surface-hover, rgba(0,0,0,0.02)); }
  .faq-a { padding: 0 var(--sp-4) var(--sp-3); font-size: var(--text-sm); line-height: 1.6; color: var(--c-text-secondary); }
  @media (max-width: 480px) {
    .direct-answer { flex-direction: column; gap: var(--sp-1); }
    .formula-cards { flex-direction: column; }
  }
</style>
