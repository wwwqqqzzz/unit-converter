---
// ============================================================
// Base HTML layout — Neo-Brutalist Design System
// Thick borders, hard offset shadows, accent yellow, zero subtlety
// ============================================================

import type { Lang } from 'converter-core/utils/i18n';
import { LANGUAGES, t, LANG_LABELS } from 'converter-core/utils/i18n';
import { hreflangTags, canonicalUrl } from 'converter-core/lib/seo';

export interface Props {
  lang: Lang;
  title: string;
  description: string;
  pagePath: string;
  isHome?: boolean;
  canonical?: string;
  jsonld?: string;
}

const { lang, title, description, pagePath, isHome, canonical, jsonld } = Astro.props;
const siteUrl = Astro.site?.href ?? 'https://unitconvert.example.com/';
const fullTitle = isHome ? title : `${title} — Unit Converter`;

const langLinks = LANGUAGES
  .filter(l => l !== lang)
  .map(l => ({ code: l, url: `/${l}/${pagePath}`, label: LANG_LABELS[l] ?? l.toUpperCase() }));

const canonicalHref = canonical ?? canonicalUrl(lang, pagePath, siteUrl.replace(/\/$/, ''));
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffe033" />
    <link rel="canonical" href={canonicalHref} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Fragment set:html={hreflangTags(pagePath)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" as="style" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    {jsonld && <script type="application/ld+json" set:html={jsonld}></script>}
    <style>
      /* ============================================================
         Neo-Brutalist Design System
         ============================================================
         Font: Space Grotesk (geometric, bold, distinctive)
         Palette: Black + White + Yellow accent
         Borders: 3px solid black (light) / 3px solid white (dark)
         Shadows: 4px 4px 0 black (light) / 4px 4px 0 white (dark)
         Radius: 0px (brutalist = no curves)
         ============================================================ */

      :root {
        --c-bg: #f5f5f0;
        --c-surface: #fff;
        --c-surface-hover: #f0f0e8;
        --c-surface-active: #e8e8dc;
        --c-border: #000;
        --c-border-light: #bbb;
        --c-text: #000;
        --c-text-secondary: #222;
        --c-text-tertiary: #555;
        --c-text-inverse: #fff;
        --c-accent: #ffe033;
        --c-accent-hover: #ffd600;
        --c-accent-dark: #c8a800;
        --c-success: #d4edda;
        --c-success-border: #000;
        --c-success-text: #155724;
        --c-hero-bg: #000;
        --c-hero-text: #fff;
        --c-hero-surface: #1a1a1a;
        --c-hero-border: #555;
        --c-hero-input-bg: #fff;
        --c-link: #000;
        --c-link-hover: #000;
        --shadow-hard: 4px 4px 0 #000;
        --shadow-hard-sm: 3px 3px 0 #000;
        --shadow-hard-xs: 2px 2px 0 #000;
        --b: 3px solid #000;
        --sp-1: 4px; --sp-2: 8px; --sp-3: 12px; --sp-4: 16px;
        --sp-5: 20px; --sp-6: 24px; --sp-8: 32px; --sp-10: 40px;
        --sp-12: 48px; --sp-16: 64px;
        --font: 'Space Grotesk', -apple-system, BlinkMacSystemFont, sans-serif;
        --font-mono: 'Space Mono', 'SF Mono', monospace;
        --text-xs: 0.75rem; --text-sm: 0.8125rem; --text-base: 0.9375rem;
        --text-lg: 1.0625rem; --text-xl: 1.25rem; --text-2xl: 1.5rem;
        --text-3xl: 2rem; --text-4xl: 2.75rem;
        --t: 100ms ease;
        --max-width: 720px;
        --max-width-wide: 960px;
        --container-pad: var(--sp-4);
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --c-bg: #0d0d0d;
          --c-surface: #1a1a1a;
          --c-surface-hover: #252525;
          --c-surface-active: #303030;
          --c-border: #e8e8e8;
          --c-border-light: #666;
          --c-text: #f0f0f0;
          --c-text-secondary: #d4d4d4;
          --c-text-tertiary: #999;
          --c-text-inverse: #000;
          --c-accent: #ffe033;
          --c-accent-hover: #ffd600;
          --c-accent-dark: #ffe033;
          --c-success: #1a3a1a;
          --c-success-border: #4a4;
          --c-success-text: #7ec77e;
          --c-hero-bg: #111;
          --c-hero-text: #f0f0f0;
          --c-hero-surface: #252525;
          --c-hero-border: #666;
          --c-hero-input-bg: #252525;
          --c-link: #f0f0f0;
          --c-link-hover: #ffe033;
          --shadow-hard: 4px 4px 0 #e8e8e8;
          --shadow-hard-sm: 3px 3px 0 #e8e8e8;
          --shadow-hard-xs: 2px 2px 0 #e8e8e8;
          --b: 3px solid #e8e8e8;
        }
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-size: 16px; scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
      body {
        font-family: var(--font);
        color: var(--c-text);
        background: var(--c-bg);
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      a { color: var(--c-link); text-decoration: underline; text-underline-offset: 2px; }
      a:hover { color: var(--c-link-hover); }
      img { max-width: 100%; height: auto; }
      h1, h2, h3, h4 { line-height: 1.2; letter-spacing: -0.02em; }
    </style>
    {import.meta.env.PROD && (
      <>
        <script is:inline src="https://www.googletagmanager.com/gtag/js?id=G-9BT1QMSP00" async></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-9BT1QMSP00');
        </script>
      </>
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href={"/" + lang + "/"} class="logo">{t(lang, 'home.title')}</a>
        <nav class="lang-switcher">
          {LANGUAGES.filter(l => l !== lang).map(l => (
            <a href={"/" + l + "/" + pagePath} class="lang-btn">
              {LANG_LABELS[l] ?? l.toUpperCase()}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="container main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p>&copy; {new Date().getFullYear()} Unit Converter</p>
        <nav>
          <a href={"/" + lang + "/"}>{t(lang, 'nav.home')}</a>
        </nav>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    background: var(--c-surface);
    border-bottom: var(--b);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--sp-3) var(--sp-4);
    max-width: var(--max-width-wide);
    margin: 0 auto;
    width: 100%;
  }
  .logo {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--c-text);
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .logo:hover { text-decoration: none; opacity: 0.8; }
  .lang-switcher { display: flex; gap: var(--sp-1); }
  .lang-btn {
    padding: var(--sp-1) var(--sp-3);
    border: var(--b);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--c-text);
    text-decoration: none;
    background: var(--c-surface);
    box-shadow: var(--shadow-hard-xs);
    transition: all var(--t);
    letter-spacing: 0.02em;
  }
  .lang-btn:hover {
    background: var(--c-accent);
    text-decoration: none;
    transform: translate(-1px, -1px);
    box-shadow: var(--shadow-hard-sm);
  }
  .lang-btn:active {
    transform: translate(2px, 2px);
    box-shadow: none;
  }
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
    padding: 0 var(--container-pad);
  }
  .main-content {
    flex: 1;
    padding-top: var(--sp-10);
    padding-bottom: var(--sp-16);
  }
  .site-footer {
    border-top: var(--b);
    padding: var(--sp-6) 0;
    background: var(--c-surface);
    font-size: var(--text-sm);
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--max-width-wide);
    margin: 0 auto;
    width: 100%;
    padding: 0 var(--container-pad);
  }
  .footer-inner nav a {
    color: var(--c-text-tertiary);
    text-decoration: none;
    margin-left: var(--sp-4);
  }
  .footer-inner nav a:hover { color: var(--c-text); text-decoration: underline; }
  @media (max-width: 480px) {
    :root { --container-pad: var(--sp-3); }
    .header-inner { padding: var(--sp-2) var(--sp-3); }
    .main-content { padding-top: var(--sp-6); }
  }
</style>
