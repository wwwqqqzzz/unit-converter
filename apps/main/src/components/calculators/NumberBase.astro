---
// Number Base Calculator — interactive base conversion
// Supports: binary (2), octal (8), decimal (10), hexadecimal (16)
interface Props { lang: string; }
const { lang } = Astro.props;
const labelValue = lang === 'zh' ? '输入数值' : 'Enter a number';
const labelFrom = lang === 'zh' ? '从' : 'From';
const labelTo = lang === 'zh' ? '到' : 'To';
const labelResult = lang === 'zh' ? '结果' : 'Result';
const labelAllReps = lang === 'zh' ? '对应值' : 'All Representations';
const labelBinary = 'Binary (2)';
const labelOctal = 'Octal (8)';
const labelDecimal = 'Decimal (10)';
const labelHex = 'Hexadecimal (16)';
const placeholder = lang === 'zh' ? '输入数字' : 'Enter a number';
lang === 'zh' ? '输入要转换的数字' : 'Enter the number you want to convert';
---

<div class="calc-card" id="number-base-root">
  <h1 class="calc-title"><slot name="title" /></h1>

  <div class="calc-row">
    <div class="calc-field">
      <label class="calc-label">{labelValue}</label>
      <input id="nb-value" type="text" class="calc-input" value="42" placeholder={placeholder} />
    </div>
  </div>

  <div class="calc-row calc-row-bases">
    <div class="calc-field">
      <label class="calc-label">{labelFrom}</label>
      <select id="nb-from" class="calc-select">
        <option value="2">{labelBinary}</option>
        <option value="8">{labelOctal}</option>
        <option value="10" selected>{labelDecimal}</option>
        <option value="16">{labelHex}</option>
      </select>
    </div>
    <div class="calc-field">
      <label class="calc-label">{labelTo}</label>
      <select id="nb-to" class="calc-select">
        <option value="2" selected>{labelBinary}</option>
        <option value="8">{labelOctal}</option>
        <option value="10">{labelDecimal}</option>
        <option value="16">{labelHex}</option>
      </select>
    </div>
  </div>

  <div class="calc-result" id="nb-result">
    <span class="calc-result-value" id="nb-result-value">101010</span>
  </div>

  <h3 class="calc-subtitle">{labelAllReps}</h3>
  <div class="nb-grid">
    <div class="nb-card"><span class="nb-label">Binary</span><span class="nb-value" id="nb-bin">101010</span></div>
    <div class="nb-card"><span class="nb-label">Octal</span><span class="nb-value" id="nb-oct">52</span></div>
    <div class="nb-card"><span class="nb-label">Decimal</span><span class="nb-value" id="nb-dec">42</span></div>
    <div class="nb-card"><span class="nb-label">Hexadecimal</span><span class="nb-value" id="nb-hex">2a</span></div>
  </div>
</div>

<script>
(function() {
  const root = document.getElementById('number-base-root');
  if (!root) return;
  const valueInput = document.getElementById('nb-value') as HTMLInputElement;
  const fromSelect = document.getElementById('nb-from') as HTMLSelectElement;
  const toSelect = document.getElementById('nb-to') as HTMLSelectElement;
  const resultDisplay = document.getElementById('nb-result-value') as HTMLElement;
  const binDisplay = document.getElementById('nb-bin') as HTMLElement;
  const octDisplay = document.getElementById('nb-oct') as HTMLElement;
  const decDisplay = document.getElementById('nb-dec') as HTMLElement;
  const hexDisplay = document.getElementById('nb-hex') as HTMLElement;

  function update() {
    const raw = valueInput.value.trim();
    const fromBase = parseInt(fromSelect.value, 10);
    const toBase = parseInt(toSelect.value, 10);
    if (!raw) { clearAll(); return; }
    const decimal = parseInt(raw, fromBase);
    if (isNaN(decimal)) { clearAll(); return; }
    const result = decimal.toString(toBase).toUpperCase();
    resultDisplay.textContent = result;
    binDisplay.textContent = decimal.toString(2).toUpperCase();
    octDisplay.textContent = decimal.toString(8).toUpperCase();
    decDisplay.textContent = decimal.toString(10);
    hexDisplay.textContent = decimal.toString(16).toUpperCase();
  }

  function clearAll() {
    const v = '—';
    resultDisplay.textContent = v;
    binDisplay.textContent = v;
    octDisplay.textContent = v;
    decDisplay.textContent = v;
    hexDisplay.textContent = v;
  }

  valueInput.addEventListener('input', update);
  fromSelect.addEventListener('change', update);
  toSelect.addEventListener('change', update);
  update();
})();
</script>

<style>
  .calc-card { background: var(--c-hero-bg); border: var(--b); box-shadow: var(--shadow-hard); padding: var(--sp-6); color: var(--c-hero-text); margin: var(--sp-8) 0; }
  .calc-title { font-size: var(--text-xl); margin-bottom: var(--sp-4); letter-spacing: -0.01em; }
  .calc-subtitle { font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--c-text-secondary); margin: var(--sp-6) 0 var(--sp-3); }
  .calc-row { margin-bottom: var(--sp-3); }
  .calc-row-bases { display: flex; gap: var(--sp-3); }
  .calc-field { flex: 1; min-width: 0; }
  .calc-label { display: block; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--c-text-secondary); margin-bottom: var(--sp-1); }
  .calc-input { width: 100%; padding: var(--sp-3) var(--sp-4); border: 2px solid var(--c-hero-border); font-size: var(--text-xl); font-weight: 600; font-family: var(--font-mono); background: var(--c-hero-input-bg); color: var(--c-text); box-sizing: border-box; }
  .calc-input:focus { outline: none; border-color: var(--c-accent); }
  .calc-select { width: 100%; padding: var(--sp-2) var(--sp-3); border: 2px solid var(--c-hero-border); font-size: var(--text-sm); font-family: var(--font); background: var(--c-hero-surface); color: var(--c-hero-text); cursor: pointer; appearance: none; padding-right: 32px; }
  .calc-select:focus { outline: none; border-color: var(--c-accent); }
  .calc-select option { color: #111; background: #fff; }
  .calc-result { background: var(--c-accent); color: #000; padding: var(--sp-4) var(--sp-5); border: 2px solid #000; margin: var(--sp-4) 0; text-align: center; }
  .calc-result-value { font-size: var(--text-2xl); font-weight: 700; font-family: var(--font-mono); word-break: break-all; }
  .nb-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: var(--sp-2); }
  .nb-card { background: var(--c-hero-surface); border: 2px solid var(--c-hero-border); padding: var(--sp-3); text-align: center; }
  .nb-label { display: block; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--c-text-secondary); margin-bottom: var(--sp-1); }
  .nb-value { display: block; font-size: var(--text-lg); font-weight: 600; font-family: var(--font-mono); word-break: break-all; }
  @media (max-width: 600px) { .calc-card { padding: var(--sp-4); } .calc-row-bases { flex-direction: column; } .calc-input { font-size: var(--text-lg); } }
  @media (prefers-color-scheme: dark) { .calc-select option { color: #f0f0f0; background: #1a1a1a; } }
</style>
