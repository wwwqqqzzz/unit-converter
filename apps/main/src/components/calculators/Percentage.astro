---
// Percentage Calculator — 3 modes: discount, increase, difference
interface Props { lang: string; }
const { lang } = Astro.props;
const modes = lang === 'zh'
  ? [
      { id: 'discount', label: '折扣计算 — X的Y%是多少？' },
      { id: 'increase', label: '增长率 — Y比X增加X%？' },
      { id: 'difference', label: '百分比差 — X是Y的百分之几？' },
    ]
  : [
      { id: 'discount', label: 'Discount — What is Y% of X?' },
      { id: 'increase', label: 'Increase — X plus Y% of X?' },
      { id: 'difference', label: 'Difference — What % is X of Y?' },
    ];
const labelMode = lang === 'zh' ? '计算模式' : 'Mode';
const labelValue = lang === 'zh' ? '数值' : 'Value';
const labelPercent = lang === 'zh' ? '百分比' : 'Percent';
const labelResult = lang === 'zh' ? '结果' : 'Result';
const labelFormula = lang === 'zh' ? '公式' : 'Formula';
const placeholderX = lang === 'zh' ? '输入数值' : 'Enter value';
const placeholderY = lang === 'zh' ? '输入百分比' : 'Enter percent';
const resultPrefix = lang === 'zh' ? '计算结果' : 'Result';
---

<div class="calc-card" id="pct-root">
  <h1 class="calc-title"><slot name="title" /></h1>

  <div class="calc-row">
    <div class="calc-field">
      <label class="calc-label">{labelMode}</label>
      <select id="pct-mode" class="calc-select">
        {modes.map(m => <option value={m.id}>{m.label}</option>)}
      </select>
    </div>
  </div>

  <div class="calc-row">
    <div class="calc-field">
      <label class="calc-label" id="pct-label-a">{labelValue} (X)</label>
      <input id="pct-val-a" type="number" class="calc-input" value="200" step="any" />
    </div>
    <div class="calc-field">
      <label class="calc-label" id="pct-label-b">{labelPercent} (Y)</label>
      <input id="pct-val-b" type="number" class="calc-input" value="15" step="any" />
    </div>
  </div>

  <div class="calc-result">
    <div class="calc-result-label">{labelResult}</div>
    <div class="calc-result-value" id="pct-result">30</div>
  </div>

  <div class="pct-formula" id="pct-formula">
    <span class="calc-label">{labelFormula}:</span>
    <code id="pct-formula-text">15% of 200 = 30</code>
  </div>
</div>

<script>
(function() {
  const root = document.getElementById('pct-root');
  if (!root) return;
  const modeSelect = document.getElementById('pct-mode') as HTMLSelectElement;
  const valA = document.getElementById('pct-val-a') as HTMLInputElement;
  const valB = document.getElementById('pct-val-b') as HTMLInputElement;
  const result = document.getElementById('pct-result') as HTMLElement;
  const formula = document.getElementById('pct-formula-text') as HTMLElement;
  const labelA = document.getElementById('pct-label-a') as HTMLElement;
  const labelB = document.getElementById('pct-label-b') as HTMLElement;

  function update() {
    const mode = modeSelect.value;
    const a = parseFloat(valA.value);
    const b = parseFloat(valB.value);
    const isZh = labelA.textContent === '数值 (X)';

    let res: number;
    let formulaText: string;

    switch (mode) {
      case 'discount': {
        // What is b% of a?
        res = a * (b / 100);
        labelA.textContent = isZh ? '原价 (X)' : 'Value (X)';
        labelB.textContent = isZh ? '折扣百分比 (Y%)' : 'Discount Percent (Y%)';
        formulaText = isZh ? `${b}% × ${a} = ${fmt(res)}` : `${b}% of ${a} = ${fmt(res)}`;
        break;
      }
      case 'increase': {
        // a + b% of a
        res = a * (1 + b / 100);
        labelA.textContent = isZh ? '原值 (X)' : 'Original Value (X)';
        labelB.textContent = isZh ? '增长百分比 (Y%)' : 'Increase Percent (Y%)';
        formulaText = isZh ? `${a} + ${b}% × ${a} = ${fmt(res)}` : `${a} + ${b}% of ${a} = ${fmt(res)}`;
        break;
      }
      case 'difference': {
        // a is what % of b?
        res = b === 0 ? NaN : (a / b) * 100;
        labelA.textContent = isZh ? '部分值 (X)' : 'Part Value (X)';
        labelB.textContent = isZh ? '总值 (Y)' : 'Total Value (Y)';
        formulaText = isZh ? `${a} ÷ ${b} × 100% = ${fmt(res)}%` : `${a} / ${b} × 100% = ${fmt(res)}%`;
        break;
      }
      default: res = NaN; formulaText = '';
    }

    if (!isFinite(res)) {
      result.textContent = '—';
    } else {
      result.textContent = fmt(res) + (mode === 'difference' ? '%' : '');
    }
    formula.textContent = formulaText;
  }

  function fmt(n: number): string {
    if (!isFinite(n)) return '—';
    const s = n.toFixed(4).replace(/\.?0+$/, '');
    return s;
  }

  modeSelect.addEventListener('change', update);
  valA.addEventListener('input', update);
  valB.addEventListener('input', update);
  update();
})();
</script>

<style>
  .calc-card { background: var(--c-hero-bg); border: var(--b); box-shadow: var(--shadow-hard); padding: var(--sp-6); color: var(--c-hero-text); margin: var(--sp-8) 0; }
  .calc-title { font-size: var(--text-xl); margin-bottom: var(--sp-4); letter-spacing: -0.01em; }
  .calc-row { display: flex; gap: var(--sp-3); margin-bottom: var(--sp-3); }
  .calc-field { flex: 1; min-width: 0; }
  .calc-label { display: block; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--c-text-secondary); margin-bottom: var(--sp-1); }
  .calc-input { width: 100%; padding: var(--sp-3) var(--sp-4); border: 2px solid var(--c-hero-border); font-size: var(--text-xl); font-weight: 600; font-family: var(--font); background: var(--c-hero-input-bg); color: var(--c-text); box-sizing: border-box; }
  .calc-input:focus { outline: none; border-color: var(--c-accent); }
  .calc-select { width: 100%; padding: var(--sp-2) var(--sp-3); border: 2px solid var(--c-hero-border); font-size: var(--text-sm); font-family: var(--font); background: var(--c-hero-surface); color: var(--c-hero-text); cursor: pointer; appearance: none; padding-right: 32px; }
  .calc-select:focus { outline: none; border-color: var(--c-accent); }
  .calc-select option { color: #111; background: #fff; }
  .calc-result { background: var(--c-accent); color: #000; padding: var(--sp-4) var(--sp-5); border: 2px solid #000; margin: var(--sp-4) 0; text-align: center; }
  .calc-result-label { font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--sp-1); }
  .calc-result-value { font-size: var(--text-2xl); font-weight: 700; font-family: var(--font-mono); }
  .pct-formula { display: flex; align-items: center; gap: var(--sp-2); padding: var(--sp-3); background: var(--c-hero-surface); border: 2px solid var(--c-hero-border); }
  .pct-formula code { font-family: var(--font-mono); font-size: var(--text-sm); }
  @media (max-width: 600px) { .calc-card { padding: var(--sp-4); } .calc-row { flex-direction: column; } .calc-result-value { font-size: var(--text-xl); } }
  @media (prefers-color-scheme: dark) { .calc-select option { color: #f0f0f0; background: #1a1a1a; } }
</style>
