---
// Cross-linking section — Neo-Brutalist
import type { Unit } from 'converter-core/data/units';
import { getUnitPairs, pairSlug } from 'converter-core/lib/units';
import { getCategory, getCategories } from 'converter-core/lib/units';
import { CATEGORY_ICONS } from 'converter-core/data/units';
import { t, type Lang } from 'converter-core/utils/i18n';

export interface Props {
  lang: Lang;
  categoryId: string;
  unit1Id: string;
  unit2Id: string;
  unit1Name: string;
  unit2Name: string;
}
const { lang: l, categoryId, unit1Id, unit2Id, unit1Name, unit2Name } = Astro.props;
const category = getCategory(categoryId);
const allPairs = category ? getUnitPairs(category) : [];
const reverseSlug = pairSlug(category?.units.find(u => u.id === unit2Id)!, category?.units.find(u => u.id === unit1Id)!, l);
const reverseLabel = t(l, 'converter.reverseLink', { unit1: unit2Name, unit2: unit1Name });
const categoryName = category?.name[l] ?? categoryId;
const seeAlsoLabel = t(l, 'converter.moreConversions', { name: categoryName });
const otherCategories = getCategories().filter(c => c.id !== categoryId);
const otherCatsLabel = t(l, 'converter.otherCategories');
---

<aside class="cross-links">
  <div class="cross-section">
    <h4>{t(l, 'converter.seeAlso')}</h4>
    <a href={"/" + l + "/" + categoryId + "/" + reverseSlug + "/"} class="reverse-link">{reverseLabel} →</a>
  </div>

  <div class="cross-section">
    <h4>{seeAlsoLabel}</h4>
    <div class="more-links">
      {allPairs.filter(([a, b]) => !(a.id === unit1Id && b.id === unit2Id) && !(a.id === unit2Id && b.id === unit1Id)).slice(0, 12).map(([a, b]) => {
        const slug = pairSlug(a, b, l);
        const label = `${a.name[l]} → ${b.name[l]}`;
        return <a href={"/" + l + "/" + categoryId + "/" + slug + "/"} class="link-pill">{label}</a>;
      })}
    </div>
  </div>

  <div class="cross-section">
    <h4>{otherCatsLabel}</h4>
    <div class="category-links">
      {otherCategories.map(cat => (
        <a href={"/" + l + "/" + cat.id + "/"} class="category-chip">
          <span class="cat-icon">{CATEGORY_ICONS[cat.id] ?? '📐'}</span>
          <span>{cat.name[l]}</span>
        </a>
      ))}
    </div>
  </div>
</aside>

<style>
  .cross-links { margin: var(--sp-10) 0 var(--sp-6); }
  .cross-section { margin-bottom: var(--sp-6); }
  .cross-section h4 {
    font-size: var(--text-xs); font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--c-text-tertiary); margin-bottom: var(--sp-3);
  }
  .reverse-link {
    display: inline-block;
    padding: var(--sp-2) var(--sp-4);
    background: var(--c-surface);
    border: var(--b);
    box-shadow: var(--shadow-hard-xs);
    color: var(--c-text);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 600;
    transition: all var(--t);
  }
  .reverse-link:hover { transform: translate(-1px, -1px); box-shadow: var(--shadow-hard-sm); text-decoration: none; }
  .reverse-link:active { transform: translate(1px, 1px); box-shadow: none; }
  .more-links { display: flex; flex-wrap: wrap; gap: var(--sp-2); }
  .link-pill {
    padding: var(--sp-1) var(--sp-3);
    background: var(--c-surface);
    border: 2px solid var(--c-border);
    color: var(--c-text-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: all var(--t);
  }
  .link-pill:hover {
    background: var(--c-surface-active);
    color: var(--c-text);
    text-decoration: none;
    border-color: var(--c-text);
  }
  .category-links { display: flex; flex-wrap: wrap; gap: var(--sp-2); }
  .category-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    padding: var(--sp-1) var(--sp-3);
    background: var(--c-accent);
    color: #000;
    border: 2px solid #000;
    box-shadow: var(--shadow-hard-xs);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 600;
    transition: all var(--t);
  }
  .category-chip:hover {
    transform: translate(-1px, -1px);
    box-shadow: var(--shadow-hard-sm);
    text-decoration: none;
  }
  .category-chip:active { transform: translate(1px, 1px); box-shadow: none; }
  .cat-icon { font-size: var(--text-base); }
</style>
