---
// Shoe Size Chart — International size comparison table
import { categories } from 'converter-core/data/units';
import type { Lang } from 'converter-core/utils/i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props || { lang: 'en' };

const shoeCat = categories.find(c => c.id === 'shoe');
const convertShoe = shoeCat?.convertFn;
if (!convertShoe) return;

// Generate common foot lengths (22 cm to 31 cm in 0.5 cm increments)
const footLengths: number[] = [];
for (let cm = 22; cm <= 31; cm += 0.5) {
  footLengths.push(cm);
}

interface Row { cm: string; us_m: string; us_w: string; uk: string; eu: string; jp: string; }
const rows: Row[] = footLengths.map(cm => ({
  cm: cm % 1 === 0 ? cm.toFixed(0) : cm.toFixed(1),
  us_m: convertShoe(cm, 'cm', 'us_m').toFixed(1),
  us_w: convertShoe(cm, 'cm', 'us_w').toFixed(1),
  uk: convertShoe(cm, 'cm', 'uk').toFixed(1),
  eu: convertShoe(cm, 'cm', 'eu').toFixed(0),
  jp: convertShoe(cm, 'cm', 'jp').toFixed(0),
}));

const labels = {
  cm: lang === 'zh' ? '脚长(cm)' : 'Foot (cm)',
  usM: lang === 'zh' ? '美码(男)' : 'US Men',
  usW: lang === 'zh' ? '美码(女)' : 'US Women',
  uk: lang === 'zh' ? '英码' : 'UK',
  eu: lang === 'zh' ? '欧码' : 'EU',
  jp: lang === 'zh' ? '日码' : 'JP',
};
---

<div class="chart-wrapper">
  <div class="chart-scroll">
    <table class="size-chart">
      <thead>
        <tr>
          <th>{labels.cm}</th>
          <th>{labels.usM}</th>
          <th>{labels.usW}</th>
          <th>{labels.uk}</th>
          <th>{labels.eu}</th>
          <th>{labels.jp}</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row, i) => (
          <tr class:list={{ 'row-even': i % 2 === 0, 'row-common': i >= 8 && i <= 16 }}>
            <td class="col-cm">{row.cm}</td>
            <td>{row.us_m}</td>
            <td>{row.us_w}</td>
            <td>{row.uk}</td>
            <td>{row.eu}</td>
            <td>{row.jp}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style>
  .chart-wrapper { margin: var(--sp-4) 0; overflow: hidden; }
  .chart-scroll { overflow-x: auto; }
  .size-chart { width: 100%; border-collapse: collapse; border: 3px solid #000; font-size: var(--text-sm); }
  .size-chart th {
    background: #000; color: #fff; padding: var(--sp-2) var(--sp-3);
    text-align: center; font-weight: 700; white-space: nowrap;
    text-transform: uppercase; letter-spacing: 0.05em; font-size: var(--text-xs);
  }
  .size-chart td {
    padding: var(--sp-2) var(--sp-3); text-align: center;
    border-bottom: 1px solid var(--c-border); font-family: var(--font-mono);
  }
  .size-chart .row-even td { background: var(--c-surface); }
  .size-chart .row-common td { background: var(--c-accent); color: #000; font-weight: 600; }
  .size-chart .col-cm { font-weight: 700; }
  .size-chart tbody tr:hover td { background: #ddd; }
  @media (prefers-color-scheme: dark) {
    .size-chart {
      border-color: #444;
    }
    .size-chart th { background: #222; color: #f0f0f0; }
    .size-chart .row-even td { background: #1a1a1a; }
    .size-chart .row-common td { background: #b8a020; color: #000; }
    .size-chart tbody tr:hover td { background: #333; }
  }
  @media (max-width: 600px) {
    .size-chart { font-size: var(--text-xs); }
    .size-chart th, .size-chart td { padding: var(--sp-1) var(--sp-2); }
  }
</style>
