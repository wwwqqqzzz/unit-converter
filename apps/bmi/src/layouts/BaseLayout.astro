---
import { LANGUAGES, t, LANG_LABELS } from 'converter-core/utils/i18n';
import type { Lang } from 'converter-core/utils/i18n';
import { hreflangTags, canonicalUrl } from 'converter-core/lib/seo';

export interface Props {
  title: string;
  description: string;
  lang: Lang;
  path: string;
}

const { title, description, lang, path } = Astro.props;
const site = 'https://bmi.example.com';
const canonical = canonicalUrl(lang, path, site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <Fragment set:html={hreflangTags(path)} />
    <link rel="alternate" hreflang="x-default" href={`${site}/en/`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --yellow: #ffe033;
        --black: #1a1a1a;
        --bg: #f5f5f0;
        --card: #fff;
        --text: #1a1a1a;
        --text-muted: #666;
        --border: 3px solid var(--black);
        --shadow: 5px 5px 0 var(--black);
        --font: 'Space Grotesk', system-ui, sans-serif;
      }
      html { font-family: var(--font); background: var(--bg); color: var(--text); }
      body { min-height: 100vh; display: flex; flex-direction: column; }
      main { flex: 1; width: 100%; max-width: 1024px; margin: 0 auto; padding: 2rem 1rem; }
      nav { background: var(--black); color: #fff; padding: 1rem 2rem; }
      nav a { color: var(--yellow); text-decoration: none; font-weight: 600; }
      nav a:hover { text-decoration: underline; }
      .lang-switcher { display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center; padding: 1rem; }
      .lang-switcher a { color: var(--text-muted); text-decoration: none; font-size: 0.875rem; }
      .lang-switcher a:hover { color: var(--black); text-decoration: underline; }
      footer { text-align: center; padding: 1rem; color: var(--text-muted); font-size: 0.75rem; border-top: var(--border); margin-top: 3rem; }
    </style>
  </head>
  <body>
    <nav>
      <a href={`/${lang}/`}>{t(lang, 'siteName')}</a>
    </nav>
    <div class="lang-switcher">
      {LANGUAGES.filter(l => l !== lang).map(l => (
        <a href={`/${l}/bmi/`}>{LANG_LABELS[l]}</a>
      ))}
    </div>
    <main>
      <slot />
    </main>
    <footer>&copy; {new Date().getFullYear()} BMI Calculator</footer>
  </body>
</html>
