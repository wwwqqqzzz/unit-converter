---
// Redirect to BMI calculator
import { hreflangTags, canonicalUrl } from 'converter-core/lib/seo';
export const prerender = true;
export async function getStaticPaths() {
  const langs = ['en','zh','es','fr','de','ja','pt','it','ko','ru','hi','tr'];
  return langs.map(lang => ({ params: { lang } }));
}
const { lang } = Astro.params;
const site = 'https://bmi.convunit.net';
const dest = `/${lang}/bmi/`;
const canonical = canonicalUrl(lang as any, 'bmi/', site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${dest}`} />
    <link rel="canonical" href={canonical} />
    <Fragment set:html={hreflangTags('bmi/', site)} />
  </head>
  <body><script is:inline>window.location.href=document.querySelector('meta[http-equiv="refresh"]').content.match(/url=(.+)/)[1];</script></body>
</html>
