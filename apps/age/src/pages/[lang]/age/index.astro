---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AgeCalc from '../../../components/Age.astro';
import { t, type Lang, LANGUAGES } from 'converter-core/utils/i18n';

export const prerender = true;
export async function getStaticPaths() {
  const langs = ['en','zh','es','fr','de','ja','pt','it','ko','ru','hi','tr'];
  return langs.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const title = t(lang, 'age', 'title') + ' | Age Calculator';
const description = t(lang, 'age', 'metaDesc');
---

<BaseLayout title={title} description={description} lang={lang} path="age/">
  <article>
    <div style="background: var(--card); border: var(--border); box-shadow: var(--shadow); padding: 2rem; margin-bottom: 2rem;">
      <AgeCalc lang={lang} />
    </div>

    <section style="background: var(--card); border: var(--border); box-shadow: var(--shadow); padding: 2rem;">
      <h2 style="font-size: 1.5rem; margin-bottom: 1rem;">{t(lang, 'age', 'faqTitle')}</h2>
      <details style="margin-bottom: 0.75rem;"><summary style="cursor: pointer; font-weight: 600;">{t(lang, 'age', 'faq1q')}</summary><p style="margin-top: 0.5rem; color: var(--text-muted);">{t(lang, 'age', 'faq1a')}</p></details>
      <details style="margin-bottom: 0.75rem;"><summary style="cursor: pointer; font-weight: 600;">{t(lang, 'age', 'faq2q')}</summary><p style="margin-top: 0.5rem; color: var(--text-muted);">{t(lang, 'age', 'faq2a')}</p></details>
      <details style="margin-bottom: 0.75rem;"><summary style="cursor: pointer; font-weight: 600;">{t(lang, 'age', 'faq3q')}</summary><p style="margin-top: 0.5rem; color: var(--text-muted);">{t(lang, 'age', 'faq3a')}</p></details>
    </section>
  </article>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["WebApplication"],
  "name": t(lang, 'age', 'title'),
  "description": t(lang, 'age', 'metaDesc'),
  "url": `https://age-calculator-2rd.pages.dev/${lang}/age/`,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "All"
})} />
