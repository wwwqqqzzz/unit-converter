---
// Age Calculator — exact age in years, months, days + next birthday
interface Props { lang: string; }
const { lang } = Astro.props;
const labelBirth = lang === 'zh' ? '出生日期' : 'Date of Birth';
const labelToday = lang === 'zh' ? '截止日期' : 'As of Date';
const labelAge = lang === 'zh' ? '年龄' : 'Your Age';
const labelYears = lang === 'zh' ? '年' : 'Years';
const labelMonths = lang === 'zh' ? '月' : 'Months';
const labelDays = lang === 'zh' ? '天' : 'Days';
const labelNextBirthday = lang === 'zh' ? '下一个生日' : 'Next Birthday';
const labelCountdown = lang === 'zh' ? '倒计时' : 'Countdown';
const labelTotal = lang === 'zh' ? '总天数' : 'Total Days';
const labelMonthsTotal = lang === 'zh' ? '总月数' : 'Total Months';
const labelWeeksTotal = lang === 'zh' ? '总周数' : 'Total Weeks';
const todayText = lang === 'zh' ? '今天' : 'Today';
---

<div class="calc-card" id="age-root">
  <h1 class="calc-title"><slot name="title" /></h1>

  <div class="age-row">
    <div class="calc-field">
      <label class="calc-label">{labelBirth}</label>
      <input id="age-birth" type="date" class="calc-input" />
    </div>
    <div class="calc-field">
      <label class="calc-label">{labelToday}</label>
      <div class="age-today-row">
        <input id="age-today" type="date" class="calc-input" />
        <button id="age-today-btn" class="calc-btn">{todayText}</button>
      </div>
    </div>
  </div>

  <div class="calc-result">
    <div class="calc-result-label">{labelAge}</div>
    <div class="age-result-main">
      <div class="age-unit"><span class="age-unit-value" id="age-years">30</span><span class="age-unit-label">{labelYears}</span></div>
      <span class="age-sep">·</span>
      <div class="age-unit"><span class="age-unit-value" id="age-months">6</span><span class="age-unit-label">{labelMonths}</span></div>
      <span class="age-sep">·</span>
      <div class="age-unit"><span class="age-unit-value" id="age-days">15</span><span class="age-unit-label">{labelDays}</span></div>
    </div>
  </div>

  <div class="age-stats">
    <div class="age-stat">
      <span class="age-stat-label">{labelTotal}</span>
      <span class="age-stat-value" id="age-total-days">11,145</span>
    </div>
    <div class="age-stat">
      <span class="age-stat-label">{labelMonthsTotal}</span>
      <span class="age-stat-value" id="age-total-months">366</span>
    </div>
    <div class="age-stat">
      <span class="age-stat-label">{labelWeeksTotal}</span>
      <span class="age-stat-value" id="age-total-weeks">1,592</span>
    </div>
    <div class="age-stat">
      <span class="age-stat-label">{labelNextBirthday}</span>
      <span class="age-stat-value" id="age-next-bday">2026-12-21</span>
    </div>
  </div>
</div>

<script>
(function() {
  const root = document.getElementById('age-root');
  if (!root) return;
  const birthInput = document.getElementById('age-birth') as HTMLInputElement;
  const todayInput = document.getElementById('age-today') as HTMLInputElement;
  const todayBtn = document.getElementById('age-today-btn') as HTMLButtonElement;
  const yearsDisplay = document.getElementById('age-years') as HTMLElement;
  const monthsDisplay = document.getElementById('age-months') as HTMLElement;
  const daysDisplay = document.getElementById('age-days') as HTMLElement;
  const totalDays = document.getElementById('age-total-days') as HTMLElement;
  const totalMonths = document.getElementById('age-total-months') as HTMLElement;
  const totalWeeks = document.getElementById('age-total-weeks') as HTMLElement;
  const nextBday = document.getElementById('age-next-bday') as HTMLElement;

  function fmtDate(d: Date): string {
    return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
  }

  function daysInMonth(y: number, m: number): number {
    return new Date(y, m, 0).getDate();
  }

  function calcAge() {
    const birthVal = birthInput.value;
    const todayVal = todayInput.value;
    if (!birthVal || !todayVal) {
      yearsDisplay.textContent = '—';
      monthsDisplay.textContent = '—';
      daysDisplay.textContent = '—';
      totalDays.textContent = '—';
      totalMonths.textContent = '—';
      totalWeeks.textContent = '—';
      nextBday.textContent = '—';
      return;
    }

    const birth = new Date(birthVal + 'T00:00:00');
    const today = new Date(todayVal + 'T00:00:00');
    if (isNaN(birth.getTime()) || isNaN(today.getTime()) || today < birth) {
      yearsDisplay.textContent = '—';
      monthsDisplay.textContent = '—';
      daysDisplay.textContent = '—';
      totalDays.textContent = '—';
      totalMonths.textContent = '—';
      totalWeeks.textContent = '—';
      nextBday.textContent = '—';
      return;
    }

    // Calculate years, months, days
    let y = today.getFullYear() - birth.getFullYear();
    let m = today.getMonth() - birth.getMonth();
    let d = today.getDate() - birth.getDate();

    if (d < 0) {
      m--;
      d += daysInMonth(today.getFullYear(), today.getMonth());
    }
    if (m < 0) {
      y--;
      m += 12;
    }

    yearsDisplay.textContent = String(y);
    monthsDisplay.textContent = String(m);
    daysDisplay.textContent = String(d);

    // Total days
    const diffMs = today.getTime() - birth.getTime();
    const diffDays = Math.floor(diffMs / (86400000));
    totalDays.textContent = diffDays.toLocaleString();
    totalMonths.textContent = String(y * 12 + m);
    totalWeeks.textContent = Math.floor(diffDays / 7).toLocaleString();

    // Next birthday
    let nextBdayDate = new Date(today.getFullYear(), birth.getMonth(), birth.getDate());
    if (nextBdayDate < today) {
      nextBdayDate = new Date(today.getFullYear() + 1, birth.getMonth(), birth.getDate());
    }
    nextBday.textContent = fmtDate(nextBdayDate);
  }

  function setToday() {
    todayInput.value = fmtDate(new Date());
    calcAge();
  }

  // Init with reasonable defaults
  const defaultBirth = new Date(1995, 5, 15); // June 15, 1995
  birthInput.value = fmtDate(defaultBirth);
  setToday();

  birthInput.addEventListener('change', calcAge);
  todayInput.addEventListener('change', calcAge);
  todayBtn.addEventListener('click', setToday);
})();
</script>

<style>
  .calc-card { background: var(--c-hero-bg); border: var(--b); box-shadow: var(--shadow-hard); padding: var(--sp-6); color: var(--c-hero-text); margin: var(--sp-8) 0; }
  .calc-title { font-size: var(--text-xl); margin-bottom: var(--sp-4); letter-spacing: -0.01em; }
  .calc-label { display: block; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--c-text-secondary); margin-bottom: var(--sp-1); }
  .calc-input { width: 100%; padding: var(--sp-3) var(--sp-4); border: 2px solid var(--c-hero-border); font-size: var(--text-lg); font-weight: 600; font-family: var(--font); background: var(--c-hero-input-bg); color: var(--c-text); box-sizing: border-box; }
  .calc-input:focus { outline: none; border-color: var(--c-accent); }
  .calc-btn { padding: var(--sp-1) var(--sp-4); background: var(--c-accent); color: #000; border: 2px solid #000; font-weight: 700; font-size: var(--text-sm); cursor: pointer; transition: all var(--t); font-family: var(--font); white-space: nowrap; }
  .calc-btn:hover { transform: translate(-1px, -1px); box-shadow: var(--shadow-hard-xs); }
  .calc-btn:active { transform: translate(1px, 1px); box-shadow: none; }
  .age-row { display: flex; gap: var(--sp-3); margin-bottom: var(--sp-3); }
  .calc-field { flex: 1; min-width: 0; }
  .age-today-row { display: flex; gap: var(--sp-2); }
  .age-today-row .calc-input { flex: 1; }
  .calc-result { background: var(--c-accent); color: #000; padding: var(--sp-4) var(--sp-5); border: 2px solid #000; margin: var(--sp-4) 0; text-align: center; }
  .calc-result-label { font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--sp-2); }
  .age-result-main { display: flex; align-items: center; justify-content: center; gap: var(--sp-2); }
  .age-unit { display: flex; flex-direction: column; align-items: center; }
  .age-unit-value { font-size: var(--text-3xl); font-weight: 700; font-family: var(--font-mono); line-height: 1; }
  .age-unit-label { font-size: var(--text-xs); font-weight: 600; text-transform: uppercase; }
  .age-sep { font-size: var(--text-2xl); font-weight: 700; color: rgba(0,0,0,0.3); }
  .age-stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: var(--sp-2); margin-top: var(--sp-4); }
  .age-stat { background: var(--c-hero-surface); border: 2px solid var(--c-hero-border); padding: var(--sp-3); text-align: center; }
  .age-stat-label { display: block; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--c-text-secondary); margin-bottom: var(--sp-1); }
  .age-stat-value { display: block; font-size: var(--text-lg); font-weight: 700; font-family: var(--font-mono); }
  @media (max-width: 600px) { .calc-card { padding: var(--sp-4); } .age-row { flex-direction: column; } .age-unit-value { font-size: var(--text-2xl); } .age-stats { grid-template-columns: repeat(2, 1fr); } }
</style>
