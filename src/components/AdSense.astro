---
// ============================================================
// Reusable AdSense placeholder.
// Set PUBLISHER_ID env var or edit the constant below after approval.
// ============================================================

export interface Props {
  /** 'top' | 'middle' | 'bottom' — controls styling */
  position?: 'top' | 'middle' | 'bottom';
  /** Optional custom class */
  class?: string;
}

const { position = 'middle' } = Astro.props;
const PUBLISHER_ID = import.meta.env.PUBLIC_ADSENSE_ID || 'ca-pub-XXXXXXXX';
const AD_SLOT = '1234567890'; // Replace with actual slot ID
---

{
  PUBLISHER_ID === 'ca-pub-XXXXXXXX' ? (
    <div class={`ad-placeholder ad-${position}`} aria-label="Advertisement placeholder">
      <p class="ad-placeholder-label">Ad</p>
      <p class="ad-placeholder-text">AdSense will appear here after setup</p>
    </div>
  ) : (
    <div class={`ad-container ad-${position}`}>
      <ins
        class="adsbygoogle"
        style="display:block"
        data-ad-client={PUBLISHER_ID}
        data-ad-slot={AD_SLOT}
        data-ad-format="auto"
        data-full-width-responsive="true"
      ></ins>
      <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </div>
  )
}

<style>
  .ad-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
    border: 2px dashed #ccc;
    border-radius: 8px;
    min-height: 90px;
    margin: 1.5rem 0;
    color: #999;
    font-size: 0.875rem;
  }
  .ad-placeholder-label {
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 1px;
    margin: 0;
  }
  .ad-placeholder-text {
    margin: 0.25rem 0 0;
  }
  .ad-container {
    margin: 1.5rem 0;
    text-align: center;
    min-height: 90px;
  }
  .ad-top { margin-top: 0; }
  .ad-bottom { margin-bottom: 0; }
</style>
