---
// Collapsible unit description for SEO content enrichment
// Uses native <details> element — SEO-crawlable, no JS required
// Minimalist monochrome: subtle border, clean typography

import type { Unit } from '../data/units';
import type { Lang } from '../utils/i18n';
import { t } from '../utils/i18n';
import { unitDescriptions } from '../data/descriptions';

export interface Props {
  lang: Lang;
  unit: Unit;
  categoryId: string;
}

const { lang, unit, categoryId } = Astro.props;
const desc = unitDescriptions[categoryId]?.[unit.id];
if (!desc) return;
const text = desc[lang];
if (!text) return;
const label = t(lang, 'converter.aboutUnit', { unit: unit.name[lang] });
---

<details class="unit-desc">
  <summary>{label}</summary>
  <p>{text}</p>
</details>

<style>
  .unit-desc {
    margin: var(--sp-2) 0;
    border: 1px solid var(--c-border);
    border-radius: var(--r-lg);
    overflow: hidden;
  }
  .unit-desc summary {
    padding: var(--sp-3) var(--sp-4);
    background: var(--c-surface);
    cursor: pointer;
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--c-text-secondary);
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    transition: background var(--t-fast);
    user-select: none;
  }
  .unit-desc summary::before {
    content: '+';
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--c-text-tertiary);
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--c-border);
    border-radius: var(--r-sm);
    flex-shrink: 0;
    transition: all var(--t-fast);
  }
  .unit-desc[open] summary::before {
    content: '−';
    background: var(--c-surface-active);
  }
  .unit-desc summary:hover {
    background: var(--c-surface-hover);
  }
  .unit-desc p {
    padding: var(--sp-4);
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--c-text-secondary);
    border-top: 1px solid var(--c-border);
  }
</style>