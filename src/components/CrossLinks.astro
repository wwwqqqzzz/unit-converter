---
// Cross-linking section — reverse link + more conversions in category + cross-category links

import type { Unit } from '../data/units';
import { getUnitPairs, pairSlug } from '../lib/units';
import { getCategory, getCategories } from '../lib/units';
import { CATEGORY_ICONS } from '../data/units';
import { t, type Lang } from '../utils/i18n';

export interface Props {
  lang: Lang;
  /** Category ID (e.g. "length") */
  categoryId: string;
  /** Unit 1 ID */
  unit1Id: string;
  /** Unit 2 ID */
  unit2Id: string;
  /** Unit 1 display name */
  unit1Name: string;
  /** Unit 2 display name */
  unit2Name: string;
}

const { lang: l, categoryId, unit1Id, unit2Id, unit1Name, unit2Name } = Astro.props;

const category = getCategory(categoryId);
const allPairs = category ? getUnitPairs(category) : [];
const reverseSlug = pairSlug(
  category?.units.find(u => u.id === unit2Id)!,
  category?.units.find(u => u.id === unit1Id)!,
  l
);
const reverseLabel = t(l, 'converter.reverseLink', { unit1: unit2Name, unit2: unit1Name });
const categoryName = category?.name[l] ?? categoryId;
const seeAlsoLabel = t(l, 'converter.moreConversions', { name: categoryName });

const otherCategories = getCategories().filter(c => c.id !== categoryId);
const otherCatsLabel = l === 'zh' ? '其他换算类别' : 'Other Conversion Categories';
---

<div class="cross-links">
  <h3>{t(l, 'converter.seeAlso')}</h3>
  <ul>
    <li>
      <a href={"/" + l + "/" + categoryId + "/" + reverseSlug + "/"}>{reverseLabel}</a>
    </li>
  </ul>

  <h3>{seeAlsoLabel}</h3>
  <ul class="more-links">
    {
      allPairs
        .filter(([a, b]) => !(a.id === unit1Id && b.id === unit2Id) && !(a.id === unit2Id && b.id === unit1Id))
        .slice(0, 12)
        .map(([a, b]) => {
          const slug = pairSlug(a, b, l);
          const label = l === 'zh'
            ? `${a.name.zh} 换算 ${b.name.zh}`
            : `${a.name.en} to ${b.name.en}`;
          return (
            <li><a href={"/" + l + "/" + categoryId + "/" + slug + "/"}>{label}</a></li>
          );
        })
    }
  </ul>

  <h3>{otherCatsLabel}</h3>
  <div class="category-links">
    {
      otherCategories.map(cat => (
        <a href={"/" + l + "/" + cat.id + "/"} class="category-link">
          <span class="cat-icon">{CATEGORY_ICONS[cat.id] ?? '📐'}</span>
          <span>{cat.name[l]}</span>
        </a>
      ))
    }
  </div>
</div>

<style>
  .cross-links {
    margin: 2rem 0;
    padding: 1rem 0;
    border-top: 1px solid #eee;
  }
  .cross-links h3 {
    font-size: 1.1rem;
    margin: 1rem 0 0.5rem;
  }
  .cross-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .cross-links li {
    margin: 0.3rem 0;
  }
  .cross-links a {
    color: #667eea;
    text-decoration: none;
  }
  .cross-links a:hover {
    text-decoration: underline;
  }
  .more-links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0.3rem 1rem;
  }
  .category-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .category-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 0.75rem;
    background: #f5f5ff;
    border: 1px solid #e0e0f0;
    border-radius: 6px;
    color: #333;
    text-decoration: none;
    font-size: 0.85rem;
    transition: background 0.15s, border-color 0.15s;
  }
  .category-link:hover {
    background: #e8e8ff;
    border-color: #667eea;
    text-decoration: none;
  }
  .cat-icon {
    font-size: 1rem;
  }
</style>