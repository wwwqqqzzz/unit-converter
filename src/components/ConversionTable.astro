---
// Quick conversion table for a unit pair
// Minimalist monochrome design — clean data table

import { formatResult } from '../lib/units';

export interface Props {
  lang: string;
  unit1Name: string;
  unit2Name: string;
  rate: number;
  values: number[];
}

const { lang, unit1Name, unit2Name, rate, values } = Astro.props;

const caption = lang === 'zh' ? `${unit1Name}换算${unit2Name}对照表` : `${unit1Name} to ${unit2Name}`;
---

<section class="conv-table-section">
  <h3>{caption}</h3>
  <div class="table-wrap">
    <table class="conv-table">
      <thead>
        <tr>
          <th scope="col">{unit1Name}</th>
          <th scope="col">{unit2Name}</th>
        </tr>
      </thead>
      <tbody>
        {values.map(v => (
          <tr>
            <td>{v} {unit1Name}</td>
            <td>{formatResult(v * rate)} {unit2Name}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<style>
  .conv-table-section {
    margin: var(--sp-8) 0;
  }
  .conv-table-section h3 {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-text-tertiary);
    margin-bottom: var(--sp-3);
  }
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .conv-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }
  .conv-table th {
    padding: var(--sp-2) var(--sp-3);
    text-align: left;
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--c-text-tertiary);
    border-bottom: 2px solid var(--c-border);
  }
  .conv-table td {
    padding: var(--sp-2) var(--sp-3);
    border-bottom: 1px solid var(--c-border);
    color: var(--c-text-secondary);
  }
  .conv-table tbody tr:hover {
    background: var(--c-surface-hover);
  }
  .conv-table tbody tr:last-child td {
    border-bottom: none;
  }

  @media (max-width: 480px) {
    .conv-table { font-size: var(--text-xs); }
    .conv-table th, .conv-table td { padding: var(--sp-1) var(--sp-2); }
  }
</style>