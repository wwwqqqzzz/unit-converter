---
// Category overview page: /[lang]/[category]/
// Lists all available unit pairs for this category

import BaseLayout from '../../../layouts/BaseLayout.astro';
import AdSense from '../../../components/AdSense.astro';
import { t, type Lang, LANGUAGES } from '../../../utils/i18n';
import { getCategory, getUnitPairs, pairSlug, valueSlug, getCommonValues } from '../../../lib/units';
import { categories, CATEGORY_ICONS } from '../../../data/units';

export interface Props {
  lang: Lang;
  category: string;
}

export function getStaticPaths() {
  const paths: Array<{ params: Props }> = [];
  for (const lang of LANGUAGES) {
    for (const cat of categories) {
      paths.push({ params: { lang, category: cat.id } });
    }
  }
  return paths;
}

const { lang, category: catId } = Astro.params as Props;
const category = getCategory(catId);
if (!category) return Astro.redirect('/404');

const pairs = getUnitPairs(category);
const catName = category.name[lang];
const catPath = `${catId}/`;
const commonValues = getCommonValues(catId);
const otherCategories = categories.filter(c => c.id !== catId);

// Breadcrumb JSON-LD
const breadcrumbJsonld = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: lang === 'zh' ? '首页' : 'Home', item: `${Astro.site}${lang}/` },
    { '@type': 'ListItem', position: 2, name: catName, item: `${Astro.site}${lang}/${catId}/` },
  ],
};

const jsonld = JSON.stringify([breadcrumbJsonld]);
---

<BaseLayout
  lang={lang}
  title={t(lang, 'category.title', { name: catName })}
  description={t(lang, 'category.description', { name: catName })}
  pagePath={catPath}
  jsonld={jsonld}
>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href={"/" + lang + "/"}>{t(lang, 'nav.home')}</a>
    <span class="sep">/</span>
    <span>{catName}</span>
  </nav>

  <h1>{t(lang, 'converter.moreConversions', { name: catName })}</h1>

  <p class="category-desc">{t(lang, 'category.description', { name: catName })}</p>

  <AdSense position="top" />

  <h2>{t(lang, 'category.choosePair')}</h2>

  <div class="pair-grid">
    {
      pairs.map(([a, b]) => {
        const slug = pairSlug(a, b, lang);
        const label = lang === 'zh'
          ? `${a.name.zh} 换算 ${b.name.zh}`
          : `${a.name.en} to ${b.name.en}`;
        return (
          <a href={"/" + lang + "/" + catId + "/" + slug + "/"} class="pair-card">
            <span class="pair-label">{label}</span>
            <span class="pair-arrow">&rarr;</span>
          </a>
        );
      })
    }
  </div>

  <AdSense position="middle" />

  <h2>{t(lang, 'category.popularConversions')}</h2>
  <div class="pair-grid">
    {
      pairs.slice(0, 6).map(([a, b]) => {
        const val = commonValues[0];
        const vs = valueSlug(val, a, b, lang);
        const label = lang === 'zh'
          ? `${val}${a.name.zh} 换算 ${b.name.zh}`
          : `${val} ${a.name.en} to ${a.name.en}`;
        return (
          <a href={"/" + lang + "/" + catId + "/" + vs + "/"} class="pair-card small">
            <span class="pair-label">{label}</span>
            <span class="pair-arrow">&rarr;</span>
          </a>
        );
      })
    }
  </div>

  <h2>{t(lang, 'category.otherCategories')}</h2>
  <div class="other-categories">
    {
      otherCategories.map(cat => (
        <a href={"/" + lang + "/" + cat.id + "/"} class="category-chip">
          <span class="cat-icon">{CATEGORY_ICONS[cat.id] ?? '📐'}</span>
          <span>{cat.name[lang]}</span>
        </a>
      ))
    }
  </div>

  <AdSense position="bottom" />
</BaseLayout>

<style>
  .breadcrumbs {
    font-size: var(--text-sm);
    margin-bottom: var(--sp-4);
    color: var(--c-text-tertiary);
    display: flex;
    align-items: center;
    gap: var(--sp-1);
  }
  .breadcrumbs a { color: var(--c-text-secondary); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--c-text); }
  .sep { opacity: 0.4; }
  h1 { font-size: var(--text-2xl); margin-bottom: var(--sp-2); letter-spacing: -0.02em; }
  .category-desc { color: var(--c-text-secondary); margin-bottom: var(--sp-6); line-height: 1.6; }
  h2 {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-text-tertiary);
    margin: var(--sp-8) 0 var(--sp-4);
  }
  .pair-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--sp-2);
  }
  .pair-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--sp-2) var(--sp-3);
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    text-decoration: none;
    color: var(--c-text);
    transition: all var(--t-fast);
    font-size: var(--text-sm);
  }
  .pair-card:hover {
    background: var(--c-surface-hover);
    border-color: var(--c-border-strong);
    text-decoration: none;
  }
  .pair-card.small {
    font-size: var(--text-xs);
    padding: var(--sp-1) var(--sp-2);
  }
  .pair-arrow {
    color: var(--c-text-tertiary);
    font-weight: 400;
    margin-left: var(--sp-1);
  }
  .other-categories {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-bottom: var(--sp-4);
  }
  .category-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    padding: var(--sp-1) var(--sp-3);
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r-full);
    color: var(--c-text-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: all var(--t-fast);
  }
  .category-chip:hover {
    background: var(--c-surface-active);
    border-color: var(--c-border-strong);
    color: var(--c-text);
    text-decoration: none;
  }
  .cat-icon {
    font-size: var(--text-base);
  }

  @media (max-width: 480px) {
    .pair-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); }
  }
</style>